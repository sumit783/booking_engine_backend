# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/booking_engine

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── SMTP (Email / OTP delivery) ───────────────────────────────────────────────
# Gmail example: use an App Password, not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Booking Engine <no-reply@bookingengine.com>"

# ── Supabase (Admin Auth) ─────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Cloudinary (Image / Document uploads) ────────────────────────────────────
# Find these in: Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
